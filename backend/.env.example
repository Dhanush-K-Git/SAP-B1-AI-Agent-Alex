# ── PostgreSQL — Supabase (cloud hosted, no Docker needed) ───────────────────
# Get this from: Supabase → Connect → Direct connection → URI
PG_DSN=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── Claude (get your key at https://console.anthropic.com) ───────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-6
CLAUDE_OPUS_MODEL=claude-opus-4-8
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001

# ── Embeddings (Voyage AI — free tier: https://dash.voyageai.com) ────────────
# provider: voyage | openai | local
EMBED_PROVIDER=voyage
EMBED_MODEL=voyage-3
EMBED_DIM=1024
EMBED_BATCH_SIZE=128
VOYAGE_API_KEY=pa-...
# OPENAI_API_KEY=

# ── SAP B1 Service Layer (HANA SQL execution over HTTP) ──────────────────────
# GET {url}?query={sql} → JSON array of rows. Generated SQL runs through this.
SERVICE_LAYER_URL=http://your-sap-server:port/api/GetMethod/GetData
SERVICE_LAYER_TIMEOUT=30
SERVICE_LAYER_ROW_CAP=1000

# ── SAP B1 Transactional API (create/update/cancel/close) ────────────────────
# Standard SAP B1 Service Layer REST API. Leave blank to disable CRUD endpoints.
SAP_SL_BASE_URL=https://your-sap-server:50000/b1s/v2
SAP_SL_COMPANY=
SAP_SL_USERNAME=
SAP_SL_PASSWORD=

# ── Web search (optional) ─────────────────────────────────────────────────────
# TAVILY_API_KEY=

# ── Demo login (hardcoded, no real auth) ─────────────────────────────────────
DEMO_USERNAME=admin
DEMO_PASSWORD=demo
